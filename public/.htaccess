DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow backend/proxy paths to pass through.
  RewriteRule ^(api|uploads)(/.*)?$ - [L]

  # Serve existing files and directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # React client-side routes fall back to index.html.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Cache static assets permanently.
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, immutable"
  </FilesMatch>

  # Never cache the HTML shell.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
